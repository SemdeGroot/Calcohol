{
  "expo": {
    "name": "Calcohol",
    "slug": "calcohol",
    "scheme": "calcohol",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android", "web"],
    "ios": {
      "bundleIdentifier": "nl.calcohol.app",
      "supportsTablet": true
    },
    "android": {
      "package": "nl.calcohol.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-font", "expo-splash-screen"]
  }
}
